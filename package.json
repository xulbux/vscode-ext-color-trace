{
  "name": "color-trace",
  "displayName": "Color Trace",
  "version": "1.0.0",
  "description": "Fast, readable color marking in the editor.",
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "colors",
    "css",
    "hex",
    "highlighting",
    "hsl",
    "markers",
    "oklab",
    "oklch",
    "rgb",
    "tailwind",
    "variables",
    "wide-gamut"
  ],
  "bugs": {
    "url": "https://github.com/xulbux/vscode-ext-color-trace/issues"
  },
  "license": "MIT",
  "author": {
    "name": "XulbuX",
    "email": "xulbux.real@gmail.com"
  },
  "maintainers": [
    "XulbuX <xulbux.real@gmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xulbux/vscode-ext-color-trace"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/xulbux"
  },
  "publisher": "xulbux",
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "node esbuild.js",
    "esbuild-watch": "node esbuild.js --watch",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "type-check": "tsc --noEmit",
    "vscode:prepublish": "node esbuild.js --production",
    "watch": "node esbuild.js --watch"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.125.0",
    "esbuild": "^0.25.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.71.0",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "configuration": {
      "title": "Color Trace",
      "properties": {
        "colorTrace.enable": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "*"
          ],
          "description": "Language IDs where Color Trace is enabled. Use `*` to enable for all, or prepend `!` to explicitly ignore a language (e.g. `!javascript`). Empty means disabled everywhere."
        },
        "colorTrace.markerType": {
          "type": "string",
          "default": "highlight",
          "enum": [
            "highlight",
            "dot-before",
            "dot-after"
          ],
          "description": "Style of the color marker."
        },
        "colorTrace.showAlpha": {
          "type": "boolean",
          "default": true,
          "description": "Whether to render color markers with their parsed transparency. If false, markers will always be fully opaque."
        },
        "colorTrace.markNamedColors": {
          "type": "boolean",
          "default": true,
          "description": "Mark named CSS colors (e.g. `red`, `tomato`, …)."
        },
        "colorTrace.markTailwind": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "*"
          ],
          "description": "Mark Tailwind CSS color classes. Language IDs to mark. Use `*` to enable for all, or prepend `!` to explicitly ignore a language."
        },
        "colorTrace.matchRgbWithNoFunction": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Mark raw RGB numbers (e.g. `255, 0, 0`) even when not wrapped in `rgb()`. Language IDs to mark. Use `*` to enable for all."
        },
        "colorTrace.matchHslWithNoFunction": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Mark raw HSL numbers (e.g. `255, 100%, 50%`) even when not wrapped in `hsl()`. Language IDs to mark. Use `*` to enable for all."
        },
        "colorTrace.useARGB": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Parse 8-character hex codes as `#AARRGGBB` instead of `#RRGGBBAA`. Language IDs to mark. Use `*` to enable for all."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "./assets/icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "__metadata": {
    "id": "39cf6240-75d9-4602-97ff-1c0b1e355e94",
