{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSameLine": true,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "objectWrap": "collapse",
  "proseWrap": "preserve",
  "quoteProps": "as-needed",
  "semi": true,
  "singleQuote": true,
  "sortImports": { "newlinesBetween": false },
  "sortPackageJson": { "sortScripts": true },
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false
}
